<div class="search-overlay" data-search-overlay aria-hidden="true">
  <div class="search-dialog" role="dialog" aria-label="Search resources">
    <div class="search-dialog__input-wrap">
      <svg class="search-dialog__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <input class="search-dialog__input"
             type="search"
             placeholder="Search resources..."
             data-search-input
             autocomplete="off"
             spellcheck="false">
      <kbd class="search-dialog__kbd">ESC</kbd>
    </div>
    <div class="search-dialog__results" data-search-results>
      <p class="search-dialog__empty">Type to search across all resources</p>
    </div>
  </div>
</div>
